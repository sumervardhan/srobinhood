# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/srobinhood?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-with-openssl-rand-base64-32

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: set to true to show "Dev login" on /login (works in Cursor's built-in browser without Google)
# ALLOW_DEV_LOGIN=true
